<Window x:Class="GestionMC.Desktop.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GestionMC Desktop"
        Height="420"
        Width="680"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F5F7">
    <Grid>
        <Border Padding="24" Background="White" BorderBrush="#FFCED4DA" BorderThickness="1" CornerRadius="6" Margin="24">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
                <TextBlock Text="Bienvenido a GestionMC Desktop" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Seleccione una opción para continuar" FontSize="14" Foreground="#555" TextAlignment="Center" Margin="0,0,0,18"/>

                <Button x:Name="BtnDescargar"
                        Content="Descargar facturas"
                        Height="42"
                        FontSize="16"
                        Margin="0,0,0,10"
                        Click="BtnDescargar_Click"/>

                <Button x:Name="BtnColores"
                        Content="Buscar colores de facturas"
                        Height="42"
                        FontSize="16"
                        Click="BtnColores_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

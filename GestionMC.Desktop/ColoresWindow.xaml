<Window x:Class="GestionMC.Desktop.ColoresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Colores de facturas"
        Height="620"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PageBackground}">

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackground" Color="#FFF4F5F7"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>
        <SolidColorBrush x:Key="BorderBrushLight" Color="#FFCED4DA"/>
    </Window.Resources>

    <Grid Margin="16" Background="{StaticResource PageBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Cédula/RUC" FontWeight="SemiBold" FontSize="14"/>
                    <TextBox x:Name="TxtCedula" Height="28" FontSize="14" TextChanged="TxtFiltro_TextChanged" CharacterCasing="Upper"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Nombre Cliente" FontWeight="SemiBold" FontSize="14"/>
                    <TextBox x:Name="TxtNombre" Height="28" FontSize="14" TextChanged="TxtFiltro_TextChanged" CharacterCasing="Upper"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Código Producto" FontWeight="SemiBold" FontSize="14"/>
                    <TextBox x:Name="TxtCodigo" Height="28" FontSize="14" TextChanged="TxtFiltro_TextChanged" CharacterCasing="Upper"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock FontWeight="SemiBold" FontSize="14"><Run Text="Color"/></TextBlock>
                    <TextBox x:Name="TxtColor" Height="28" FontSize="14" TextChanged="TxtFiltro_TextChanged" CharacterCasing="Upper"/>
                </StackPanel>

            </Grid>
        </Border>

        <DataGrid x:Name="GridColores"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserSortColumns="False"
                  CanUserResizeColumns="False"
                  CanUserResizeRows="False"
                  FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Cédula" Binding="{Binding Cedula}" Width="120"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Número de venta" Binding="{Binding NumeroVenta}" Width="140"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="110"/>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoItem}" Width="120"/>
                <DataGridTextColumn Header="Ítem" Binding="{Binding NombreItem}" Width="220"/>
                <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="140"/>
                <DataGridTextColumn Header="Precio con IVA" Binding="{Binding PrecioConIva, StringFormat=N2}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Margin="0,10,0,0" Padding="8" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
            <TextBlock x:Name="LblStatus" Text="Listo." TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
